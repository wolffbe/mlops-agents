@inproceedings{gadde_hey_2025,
	title = {Hey {AI}, {Generate} {Me} a {Hardware} {Code}! {Agentic} {AI}-based {Hardware} {Design} \& {Verification}},
	url = {https://ieeexplore.ieee.org/document/11218681},
	doi = {10.1109/SBCCI66862.2025.11218681},
	abstract = {Modern Integrated Circuits (ICs) are becoming increasingly complex, and so is their development process. Hardware design verification entails a methodical and disciplined approach to the planning, development, execution, and sign-off of functionally correct hardware designs. This tedious process requires significant effort and time to ensure a bug-free tape-out. The field of Natural Language Processing has undergone a significant transformation with the advent of Large Language Models (LLMs). These powerful models, often referred to as Generative AI (GenAI), have revolutionized how machines understand and generate human language, enabling unprecedented advancements in a wide array of applications, including hardware design verification. This paper presents an agentic AI-based approach to hardware design verification, which empowers AI agents, in collaboration with Human-in-the-Loop (HITL) intervention, to engage in a more dynamic, iterative, and self-reflective process, ultimately performing end-to-end hardware design and verification. This methodology is evaluated on five open-source designs, achieving over 95 \% coverage with reduced verification time while demonstrating superior performance, adaptability, and configurability.},
	urldate = {2026-03-31},
	booktitle = {2025 38th {SBC}/{SBMicro}/{IEEE} {Symposium} on {Integrated} {Circuits} and {Systems} {Design} ({SBCCI})},
	author = {Gadde, Deepak Narayan and Radhakrishna, Keerthan Kopparam and Viswambharan, Vaisakh Naduvodi and Kumar, Aman and Lettnin, Djones and Kunz, Wolfgang and Simon, Sebastian},
	month = aug,
	year = {2025},
	keywords = {Adaptation models, Agentic AI, Analytical models, Collaboration, Formal Verification, Hardware, Hardware Design, Integrated circuits, Iterative methods, LLM, Large language models, Natural language processing, Planning, Scalability},
	pages = {1--5},
}

@article{el-deeb_ai_2025,
	title = {{AI} {Copilots}: {Boosting} {Software} {Engineers}' {Productivity} {Or} {Replacing} {Them}?},
	volume = {50},
	issn = {0163-5948},
	shorttitle = {{AI} {Copilots}},
	url = {https://dl.acm.org/doi/10.1145/3743095.3743098},
	doi = {10.1145/3743095.3743098},
	abstract = {If you were born before Gen Z, you know what it means to do things the hardcore way. Remember that research paper you had to spend days digging through library books to complete? Or the painful hours it took to set up a network game? Or getting an Atari to work on your living room TV? Or having to manually handle ArrayIndexOutOfBounds exceptions while coding in C++? Everything took time, effort, and a bit of grit. We've come a long way since then, thanks to the rise of the internet and the magic of Google. But now, we're stepping into a new era-one defined by an unprecedented wave of coding productivity, driven by AI. Enter Copilots: AI-powered assistants embedded into development tools and workflows. They help you write code, debug, test, and accelerate your work. They're called ''copilots'' for a reason- like in aviation, they're intelligent teammates flying with you toward a shared goal. They're not replacing you. They don't work for you. They work with you. This paper explores the latest developments in AI Copilots and what they mean for the role of software engineers in this new frontier.},
	language = {en},
	number = {3},
	urldate = {2026-03-31},
	journal = {ACM SIGSOFT Software Engineering Notes},
	author = {El-Deeb, Ahmed},
	month = jul,
	year = {2025},
	pages = {12--13},
}

@article{liu_large_2026,
	title = {Large {Language} {Model}-{Based} {Agents} for {Software} {Engineering}: {A} {Survey}},
	issn = {1049-331X, 1557-7392},
	shorttitle = {Large {Language} {Model}-{Based} {Agents} for {Software} {Engineering}},
	url = {https://dl.acm.org/doi/10.1145/3796507},
	doi = {10.1145/3796507},
	abstract = {The recent advance in Large Language Models (LLMs) has shaped a new paradigm of AI agents,
              i.e.,
              LLM-based agents. Compared to standalone LLMs, LLM-based agents substantially extend the versatility and expertise of LLMs by enhancing LLMs with the capabilities of perceiving and utilizing external resources and tools. To date, LLM-based agents have been applied and shown remarkable effectiveness in Software Engineering (SE). The synergy between multiple agents and human interaction brings further promise in tackling complex real-world SE problems. In this work, we present a comprehensive and systematic survey on LLM-based agents for SE. We collect 124 papers and categorize them from two perspectives,
              i.e.,
              the SE and agent perspectives. In addition, we discuss open challenges and future directions in this critical domain. The repository of this survey is at
