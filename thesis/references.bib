@inproceedings{higuchi_mcp-based_2025,
	title = {{MCP}-based {AI} coding agent {Integrating} {Static} {Analysis} for {Web} {Accessibility} {Error} {Correction}},
	url = {https://ieeexplore.ieee.org/document/11338660},
	abstract = {While ensuring web accessibility is becoming a legal obligation, 94.8\% of the top one million websites violate WCAG standards, highlighting the need for more efficient implementation support in development environments. This paper proposes a novel approach to ensuring web accessibility using general-purpose AI coding agents by providing them with appropriate contextual information for accessibility error correction through a Model Context Protocol (MCP) server. This approach enables integration of Biome’s static analysis with the flexible code-base understanding capabilities of AI coding agents to efficiently produce WCAG-compliant fixes. Adopting the MCP architecture enables uniform use across various AI coding agent environments, such as Claude Code and Roo Code. We conducted experiments using an AI coding agent with four different LLM backends on a common test case and demonstrated the feasibility of our approach.},
